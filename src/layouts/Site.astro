---
// Shared shell for every custom (non-Starlight) page: landing, blog, and
// whatever comes next. Head meta, header, and footer live here once.
import BrandIcon from "../components/BrandIcon.astro";
import fastagent from "../generated/fastagent.json";
import { OG_IMAGE, SITE } from "../site";
import "../styles/custom.css";

interface Props {
  title: string;
  description: string;
  /** Canonical path, e.g. "/blog/". */
  path?: string;
  ogType?: "website" | "article";
}

const { title, description, path = "/", ogType = "website" } = Astro.props;
const canonical = `${SITE}${path}`;
---

<!doctype html>
<html lang="en" data-theme="fastagent">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0c0b" />
    <script is:inline>
      /* Pre-paint theme pick — shares the "starlight-theme" key with the docs,
         so toggling on either surface follows you to the other. */
      document.documentElement.dataset.mode = (() => {
        let stored = null;
        try {
          stored = localStorage.getItem("starlight-theme");
        } catch {
          /* storage blocked (private mode) — fall through to the system pick */
        }
        if (stored === "light" || stored === "dark") return stored;
        return matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      })();
      if (document.documentElement.dataset.mode === "light")
        document.querySelector('meta[name="theme-color"]').setAttribute("content", "#f4f7f5");
    </script>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title="FastAgent Blog" href="/blog/rss.xml" />
    <link rel="preload" href="/fonts/plex-mono-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plex-mono-600.woff2" as="font" type="font/woff2" crossorigin />
    <meta property="og:site_name" content="FastAgent" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={OG_IMAGE.url} />
    <meta property="og:image:width" content={OG_IMAGE.width} />
    <meta property="og:image:height" content={OG_IMAGE.height} />
    <meta property="og:image:alt" content={OG_IMAGE.alt} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script>
      import "../scripts/plausible";

      document.querySelector(".theme-toggle")?.addEventListener("click", () => {
        const next = document.documentElement.dataset.mode === "light" ? "dark" : "light";
        document.documentElement.dataset.mode = next;
        document.querySelector('meta[name="theme-color"]')?.setAttribute("content", next === "light" ? "#f4f7f5" : "#0a0c0b");
        try {
          localStorage.setItem("starlight-theme", next);
        } catch {
          /* storage blocked — the toggle still works for this page view */
        }
      });
    </script>
    <slot name="head" />
  </head>
  <body class="site">
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <nav class="shell nav" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="FastAgent home">
          <img class="logo-dark" src="/logo.png" alt="FastAgent" width="940" height="312" />
          <img class="logo-light" src="/logo-light.png" alt="FastAgent" width="940" height="312" />
        </a>
        <a class="brand-version" href="https://github.com/fastagent-sh/fastagent/releases" title="Release notes">v{fastagent.version}</a>
        <div class="nav-links">
          <a href="/docs/">Docs</a>
          <a href="/blog/">Blog</a>
          <a href="/docs/spec/">SPEC</a>
          <button class="theme-toggle" type="button" aria-label="Toggle light / dark theme">
            <span class="tt-sun" aria-hidden="true">☀</span>
            <span class="tt-moon" aria-hidden="true">☾</span>
          </button>
          <a class="nav-cta" href="https://github.com/fastagent-sh/fastagent">
            <BrandIcon name="github" size={13} />
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <div class="footer-brand">
          <img class="footer-mark" src="/logo-mark.png" alt="" width="512" height="512" />
          <span>
            <strong>fastagent</strong> · MIT · open source · © {new Date().getFullYear()}
            <br />
            <span class="footer-tag">Vibe first. Then FastAgent.</span>
          </span>
        </div>
        <div class="footer-links">
          <a href="/docs/">Docs</a>
          <a href="/blog/">Blog</a>
          <a href="/docs/spec/">SPEC</a>
          <a href="https://github.com/fastagent-sh/fastagent">GitHub</a>
          <a href="https://github.com/fastagent-sh/fastagent/releases">Releases</a>
          <a href="https://www.npmjs.com/package/@fastagent-sh/fastagent">npm</a>
        </div>
      </div>
    </footer>
  </body>
</html>
