---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import Site from "../../layouts/Site.astro";
import { BLOG_DESCRIPTION } from "../../site";

const posts = (await getCollection("blog")).sort((a, b) => +b.data.date - +a.data.date);
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Site title="Blog — FastAgent" description={BLOG_DESCRIPTION} path="/blog/">
  <section class="section shell blog-index">
    <header class="section-head">
      <span class="section-index"><span class="hash">#</span> blog</span>
      <h1>Shipping <em>notes</em>.</h1>
      <p class="section-lede">
        {BLOG_DESCRIPTION} Subscribe via <a class="text-link" href="/blog/rss.xml">RSS</a>.
      </p>
    </header>

    <div class="blog-controls">
      <input
        id="blog-search"
        class="blog-search"
        type="search"
        placeholder="Search posts…"
        aria-label="Search posts"
      />
      <div class="blog-tags" aria-label="Browse by tag">
        {tags.map(([tag, count]) => (
          <a class="post-tag tag-link" href={`/blog/tags/${tag}/`}># {tag} <span class="tag-count">{count}</span></a>
        ))}
      </div>
    </div>

    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
    <p class="blog-empty" hidden>No posts match — try another search.</p>
  </section>

  <script>
    const input = document.querySelector<HTMLInputElement>("#blog-search");
    const cards = [...document.querySelectorAll<HTMLElement>(".post-card")];
    const empty = document.querySelector<HTMLElement>(".blog-empty");
    input?.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      let shown = 0;
      for (const card of cards) {
        const hit = !q || (card.dataset.search ?? "").includes(q);
        card.hidden = !hit;
        if (hit) shown++;
      }
      if (empty) empty.hidden = shown > 0;
    });
  </script>
</Site>
