---
import { Code } from "astro:components";
import BrandIcon from "../components/BrandIcon.astro";
import { fastagentCode } from "../code-theme";
import CopyPrompt from "../components/CopyPrompt.astro";
import HeroMock from "../components/HeroMock.astro";
import Site from "../layouts/Site.astro";
import fastagent from "../generated/fastagent.json";
import { DEFAULT_PROMPT, DESCRIPTION as description, SITE as site } from "../site";

const title = "FastAgent — Ship your AI agent as a live service";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "FastAgent",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Node.js, Bun",
    description,
    url: site,
    softwareVersion: fastagent.version,
    codeRepository: "https://github.com/fastagent-sh/fastagent",
    license: "https://github.com/fastagent-sh/fastagent/blob/main/LICENSE",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "FastAgent",
    url: site,
    logo: `${site}/logo-mark.png`,
    sameAs: ["https://github.com/fastagent-sh", "https://www.npmjs.com/package/@fastagent-sh/fastagent"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "FastAgent",
    url: site,
  },
];

const npmInstall = "npm i -g @fastagent-sh/fastagent";
const npmEmbed = "npm i @fastagent-sh/fastagent";

/* One list drives both the section-04 tabs and the ecosystem strip's
   "embed in" group ("Your code" appears only as a tab). */
const embedFrameworks = [
  {
    id: "code",
    label: "Your code",
    icon: "typescript",
    code: `// anywhere in your codebase — a job, a queue consumer, a test
import { collect } from "@fastagent-sh/fastagent";

const { text } = await collect(
  agent.invoke({ session: "job-42" }, { text: "summarize today's failures" })
);`,
  },
  {
    id: "next",
    label: "Next.js",
    icon: "nextdotjs",
    color: "#ffffff",
    code: `// app/api/invoke/route.ts
import { createInvokeHandler, createPiAgentFromDefinition } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "openai-codex/gpt-5.5",
});

export const POST = createInvokeHandler(agent);
export const runtime = "nodejs";`,
  },
  {
    id: "hono",
    label: "Hono",
    icon: "hono",
    color: "#e36002",
    code: `// app.ts
import { Hono } from "hono";
import { createInvokeHandler, createPiAgentFromDefinition } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "anthropic/claude-sonnet-4",
});

const app = new Hono();
app.post("/invoke", createInvokeHandler(agent));

export default app;`,
  },
  {
    id: "express",
    label: "Express",
    icon: "express",
    color: "#ffffff",
    code: `// app.ts
import express from "express";
import { createInvokeHandler, createPiAgentFromDefinition, nodeListener } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "anthropic/claude-sonnet-4",
});

const app = express();
app.post("/invoke", nodeListener(createInvokeHandler(agent))); // no body parser on this route
app.listen(8787);`,
  },
  {
    id: "astro",
    label: "Astro",
    icon: "astro",
    color: "#bc52ee",
    code: `// src/pages/api/invoke.ts
import { createInvokeHandler, createPiAgentFromDefinition } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "openai-codex/gpt-5.5",
});

export const POST = createInvokeHandler(agent);`,
  },
  {
    id: "nuxt",
    label: "Nuxt",
    icon: "nuxtdotjs",
    color: "#00dc82",
    code: `// server/api/invoke.post.ts
import { createInvokeHandler, createPiAgentFromDefinition } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "openai-codex/gpt-5.5",
});
const handler = createInvokeHandler(agent);

export default defineEventHandler((event) => handler(toWebRequest(event)));`,
  },
  {
    id: "svelte",
    label: "SvelteKit",
    icon: "svelte",
    color: "#ff3e00",
    code: `// src/routes/invoke/+server.ts
import { createInvokeHandler, createPiAgentFromDefinition } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "anthropic/claude-sonnet-4",
});
const handler = createInvokeHandler(agent);

export const POST = ({ request }) => handler(request);`,
  },
  {
    id: "fastify",
    label: "Fastify",
    icon: "fastify",
    color: "#ffffff",
    code: `// server.ts — keep the body stream unread, hijack the reply
import { createInvokeHandler, createPiAgentFromDefinition, nodeListener } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "openai-codex/gpt-5.5",
});
const listener = nodeListener(createInvokeHandler(agent));

app.register(async (scope) => {
  scope.removeAllContentTypeParsers();
  scope.addContentTypeParser("*", (_req, payload, done) => done(null, payload));
  scope.post("/invoke", (req, reply) => { reply.hijack(); listener(req.raw, reply.raw); });
});`,
  },
  {
    id: "bun",
    label: "Bun",
    icon: "bun",
    color: "#fbf0df",
    code: `// server.ts
import { createInvokeHandler, createPiAgentFromDefinition } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "openai-codex/gpt-5.5",
});

const invoke = createInvokeHandler(agent);

Bun.serve({
  port: 8787,
  fetch(req) {
    const url = new URL(req.url);
    return url.pathname === "/invoke" ? invoke(req) : new Response("ok");
  },
});`,
  },
  {
    id: "node",
    label: "Node",
    icon: "nodedotjs",
    color: "#5fa04e",
    code: `// server.ts
import { createInvokeHandler, createPiAgentFromDefinition, router, serveNode } from "@fastagent-sh/fastagent";

const { agent } = await createPiAgentFromDefinition("./agent", {
  model: "openai-codex/gpt-5.5",
});

serveNode(router({ "POST /invoke": createInvokeHandler(agent) }), { port: 8787 });`,
  },
];

const ecosystem = [
  {
    group: "channels",
    items: [
      { icon: "github", label: "GitHub", color: "#ffffff" },
      { icon: "telegram", label: "Telegram", color: "#26a5e4" },
      { icon: "slack", label: "Slack", color: "#e01e5a" },
      { icon: "discord", label: "Discord", color: "#5865f2", soon: true },
      { icon: "whatsapp", label: "WhatsApp", color: "#25d366", soon: true },
      { icon: "gitlab", label: "GitLab", color: "#fc6d26", soon: true },
    ],
    more: "+ more",
  },
  {
    group: "connect",
    items: [
      { icon: "stripe", label: "Stripe", color: "#635bff", soon: true },
      { icon: "shopify", label: "Shopify", color: "#95bf47", soon: true },
      { icon: "notion", label: "Notion", color: "#ffffff", soon: true },
      { icon: "salesforce", label: "Salesforce", color: "#00a1e0", soon: true },
      { icon: "googledocs", label: "Google Docs", color: "#4285f4", soon: true },
      { icon: "facebook", label: "Facebook", color: "#0866ff", soon: true },
      { icon: "pinterest", label: "Pinterest", color: "#e60023", soon: true },
    ],
    more: "+ more",
  },
  {
    group: "embed in",
    items: embedFrameworks.filter((f) => f.id !== "code").map(({ icon, label, color }) => ({ icon, label, color, soon: undefined })),
  },
  {
    group: "deploy to",
    items: [
      { icon: "flydotio", label: "Fly.io", color: "#b794f6" },
      { icon: "railway", label: "Railway", color: "#ffffff" },
      { icon: "docker", label: "Docker", color: "#2496ed" },
      { icon: "cloudflare", label: "Cloudflare", color: "#f38020", soon: true },
      { icon: "vercel", label: "Vercel", color: "#ffffff", soon: true },
      { icon: "render", label: "Render", color: "#46e3b7", soon: true },
      { icon: "amazonwebservices", label: "AWS", color: "#ff9900", soon: true },
      { icon: "kubernetes", label: "Kubernetes", color: "#326ce5", soon: true },
      { icon: "googlecloud", label: "Google Cloud", color: "#4285f4", soon: true },
    ],
  },
  {
    group: "models",
    items: [
      { icon: "anthropic", label: "Anthropic", color: "#d97757" },
      { icon: "openai", label: "OpenAI", color: "#ffffff" },
      { icon: "googlegemini", label: "Gemini", color: "#8e75b2" },
      { icon: "deepseek", label: "DeepSeek", color: "#4d6bfe", soon: true },
      { icon: "qwen", label: "Qwen", color: "#615ced", soon: true },
      { icon: "moonshotai", label: "Kimi", color: "#ffffff" },
      { icon: "meta", label: "Llama", color: "#0467df", soon: true },
      { icon: "ollama", label: "Ollama", color: "#ffffff" },
      { icon: "huggingface", label: "Hugging Face", color: "#ffd21e" },
    ],
    more: "+ more",
  },
];

/* Section 06 renders the same deploy list — single source of truth. */
const deployTargets = ecosystem.find((g) => g.group === "deploy to")!.items;



/* A curated five of the public concept set (docs/principles.md, “Concepts before
   features”) — Event and Session complete the set there. */
const concepts = [
  { term: "Agent Definition", meaning: "the directory that describes the agent" },
  { term: "Agent Handler", meaning: "the callable contract: invoke" },
  { term: "Tool", meaning: "a typed action, validated before execution" },
  { term: "Skill", meaning: "reusable expertise loaded from the definition" },
  { term: "Channel", meaning: "turns an external event — a webhook, a message, even the clock — into invocations" },
];
---

<Site title={title} description={description} path="/">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} slot="head" />
      <!-- HERO ──────────────────────────────────────────────────────── -->
      <section class="hero shell">
        <div class="hero-left">
          <p class="eyebrow"><span class="hash">#</span> ship your agent as a live service — any channel, any app</p>
          <h1>Vibe first.<br /><em>Then FastAgent.</em></h1>
          <p class="hero-lede">
            An agent is <strong>just a directory</strong> (persona.md, skills/, tools/, channels/) —
            or embedded right in your app. FastAgent serves it: GitHub, Telegram, Slack, Feishu,
            or any channel you compose. <strong>No rewrite, no new format, no platform.</strong>
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/docs/quickstart/">Quick start</a>
            <a class="btn btn-secondary" href="/docs/">Read the docs</a>
          </div>

          <div class="install-panel" aria-label="Start options">
            <input type="radio" name="im" id="im-agent" class="tabs-radio" checked />
            <input type="radio" name="im" id="im-term" class="tabs-radio" />
            <div class="install-methods">
              <span class="install-title">start</span>
              <label for="im-agent" data-im="agent">For agents</label>
              <label for="im-term" data-im="term">For humans</label>
            </div>
            <div class="install-card" data-im-panel="agent">
              <span class="ip">❯</span>
              <code class="is-truncated" title={DEFAULT_PROMPT}>{DEFAULT_PROMPT}</code>
              <button type="button" data-copy-prompt={DEFAULT_PROMPT} data-track-method="agent-prompt" data-track-placement="hero">Copy</button>
            </div>
            <div class="install-card" data-im-panel="term">
              <span class="ip">$</span>
              <code>{npmInstall}</code>
              <span class="cmd-note"># cli</span>
              <button type="button" data-copy-prompt={npmInstall} data-track-method="npm-cli" data-track-placement="hero">Copy</button>
            </div>
            <div class="install-card stack" data-im-panel="term">
              <span class="ip">$</span>
              <code>{npmEmbed}</code>
              <span class="cmd-note"># embed in your app</span>
              <button type="button" data-copy-prompt={npmEmbed} data-track-method="npm-embed" data-track-placement="hero">Copy</button>
            </div>
          </div>

          <p class="hero-note">MIT · Node ≥ 22.19 / Bun · harness-neutral · no account, no telemetry</p>
          <script>
            import { track } from "@plausible-analytics/tracker";
            import "../scripts/copy";
            // Which embed target people reach for — prioritizes the "soon" integrations.
            for (const input of document.querySelectorAll<HTMLInputElement>('input[name="fw"]')) {
              input.addEventListener("change", () => track("embed-tab", { props: { framework: input.id.replace("fw-", "") } }));
            }
          </script>
        </div>

        <div class="hero-right">
          <HeroMock />
        </div>
      </section>

      <!-- ECOSYSTEM STRIP ───────────────────────────────────────────── -->
      <section class="eco" aria-label="Works with">
        <div class="shell eco-inner">
          <span class="eco-label"># the ecosystem — plugs into your stack and infrastructure</span>
          <div class="eco-groups">
            {ecosystem.map((g) => (
              <div class="eco-group">
                <span class="eco-group-label">{g.group}</span>
                <ul class="eco-list">
                  {g.items.map((e) => (
                    <li class:list={[{ "eco-soon": e.soon }]} title={e.soon ? "coming soon" : undefined}>
                      {e.icon && <BrandIcon name={e.icon} size={15} color={e.soon ? undefined : e.color} />} {e.label}{e.soon && <span class="sr-only"> (coming soon)</span>}
                    </li>
                  ))}
                  {g.more && <li class="eco-more">{g.more}</li>}
                </ul>
              </div>
            ))}
          </div>
          <span class="eco-legend">more integrations coming soon</span>
        </div>
      </section>

      <!-- 01 THE CORE ------------------------------------------------ -->
      <section class="section shell" aria-labelledby="core-title">
        <header class="section-head">
          <span class="section-index"><span class="hash">#</span> 01 · the core</span>
          <h2 id="core-title">Small core. <em>Clear seams.</em></h2>
          <p class="section-lede">
            FastAgent owns exactly one thing: a single function — the <strong>Agent Handler</strong>.
            It decouples your channels, your agent, the harness, and your infra — swap any
            of them without touching the others.
          </p>
        </header>

        <div class="core-diagram">
          <div class="core-col">
            <span class="core-col-label">channels</span>
            <span class="core-col-sub">turn external events into invocations</span>
            <ul>
              <li>GitHub webhooks</li>
              <li>Telegram · Discord · Slack bots</li>
              <li>HTTP API · SSE streaming</li>
              <li>cron schedules</li>
              <li class="core-yours">+ yours · via the channel kit</li>
            </ul>
          </div>
          <span class="core-arrow" aria-hidden="true">→</span>
          <div class="core-center">
            <span class="core-center-label">agent handler · the contract</span>
            <pre class="core-sig"><code><span class="ct-fn">invoke</span>(<span class="ct-arg">scope</span>, <span class="ct-arg">prompt</span>)
  =&gt; <span class="tg">AsyncIterable</span>&lt;<span class="tty">AgentEvent</span>&gt;</code></pre>
            <span class="core-center-sub">powered by <a href="https://pi.dev">pi</a> — the built-in agent harness</span>
            <span class="core-center-sub core-yours-inline">+ or bring your own harness</span>
          </div>
          <span class="core-arrow" aria-hidden="true">→</span>
          <div class="core-col">
            <span class="core-col-label">infra</span>
            <span class="core-col-sub">yours — owns auth, storage, deployment</span>
            <ul>
              <li>your app's route</li>
              <li>node · bun server</li>
              <li>fly · railway · docker</li>
              <li class="core-yours">+ yours · anything fetch-shaped</li>
            </ul>
          </div>
        </div>

        <p class="design-center"><span class="hash">#</span> one contract collapses the channels × harnesses × infra matrix</p>

        <div class="event-flow" aria-label="AgentEvent stream">
          <span class="ev-label">each turn streams</span>
          <span class="ev ev-text">text</span>
          <span class="ev ev-text">thinking</span>
          <span class="ev ev-tool">tool_started</span>
          <span class="ev ev-tool">tool_ended</span>
          <span class="ev-sep" aria-hidden="true">→</span>
          <span class="ev ev-done">completed</span>
          <span class="ev-or">|</span>
          <span class="ev ev-fail">failed</span>
        </div>

        <div class="concepts" aria-label="The public concept set">
          <span class="concepts-label"># the whole system in five words</span>
          <dl class="concept-list">
            {concepts.map((c) => (
              <div class="concept">
                <dt>{c.term}</dt>
                <dd>{c.meaning}</dd>
              </div>
            ))}
          </dl>
        </div>

        <p class="section-follow"><a class="text-link" href="/docs/spec/">Read the Agent Handler SPEC →</a> · <a class="text-link" href="/docs/principles/">Design principles →</a></p>
      </section>

      <!-- 02 EXTENSIONS BY COMPOSITION --------------------------------- -->
      <section class="section shell" aria-labelledby="seams-title">
        <header class="section-head">
          <span class="section-index"><span class="hash">#</span> 02 · composition</span>
          <h2 id="seams-title">Compose the modules.<br /><em>Extend with a file.</em></h2>
          <p class="section-lede">
            Every part of FastAgent is a module: model, sessions, providers, channels, tools.
            Composing them is plain TypeScript — and extending is dropping a file that
            composes in. Built for your scenario and your stack, without forks or waiting.
          </p>
        </header>

        <div class="demo-grid">
          <div class="demo-win tint-teal">
            <div class="demo-bar">
              <span class="demo-glyph">⊕</span>
              <span>compose · every option is a module</span>
            </div>
            <div class="demo-body code-pane">
              <p><span class="tkw">const</span> {'{'} agent {'}'} = <span class="tkw">await</span> <span class="ct-fn">createPiAgentFromDefinition</span>(<span class="tstr">"./agent"</span>, {'{'}</p>
              <p>  model: <span class="tstr">"anthropic/claude-sonnet-4"</span>,              <span class="tdim">// any provider</span></p>
              <p>  sessions: <span class="ct-fn">jsonlSessionStore</span>({'{'} dir: <span class="tstr">".state"</span> {'}'}),  <span class="tdim">// or your own store</span></p>
              <p>  providers: [myGateway],                          <span class="tdim">// or your model gateway</span></p>
              <p>{'}'});</p>
              <footer class="demo-foot">▸ assembly is code — swap any module, the rest keeps working</footer>
            </div>
          </div>

          <div class="demo-win tint-amber">
            <div class="demo-bar">
              <span class="demo-glyph">+</span>
              <span>extend · tools/lookup-order.ts</span>
            </div>
            <div class="demo-body code-pane">
              <p><span class="tdim">// the filename becomes the tool name</span></p>
              <p><span class="tkw">export default</span> <span class="ct-fn">defineTool</span>({'{'}</p>
              <p>  description: <span class="tstr">"Look up an order by id."</span>,</p>
              <p>  input: z.object({'{'} orderId: z.string() {'}'}),</p>
              <p>  <span class="tkw">async</span> <span class="ct-fn">execute</span>({'{'} orderId {'}'}) {'{'} <span class="tkw">return</span> db.find(orderId); {'}'},</p>
              <p>{'}'});</p>
              <footer class="demo-foot">▸ drop a file into tools/, channels/, or schedules/ — it composes in</footer>
            </div>
          </div>
        </div>

        <p class="section-follow"><a class="text-link" href="/docs/channel-development/">Build a channel adapter →</a> · <a class="text-link" href="/docs/api-reference/">Public API surface →</a></p>
      </section>

      <!-- 03 THE DEFINITION ──────────────────────────────────────────────────── -->
      <section class="section shell" aria-labelledby="shape-title">
        <header class="section-head">
          <span class="section-index"><span class="hash">#</span> 03 · the definition</span>
          <h2 id="shape-title">The directory <em>is</em> the agent.</h2>
          <p class="section-lede">
            Vibed with a coding agent, written by hand, or inherited from a repo —
            a plain directory is the <strong>definition</strong>. FastAgent assembles it
            at boot. No DSL, no rewrite.
          </p>
        </header>

        <div class="shape-grid">
          <pre class="term-block filetree" aria-label="Example FastAgent directory"><code><span class="ft-dir">agent/</span>
├─ persona.md            <span class="ft-note"># identity + standing instructions</span>
├─ AGENTS.md             <span class="ft-note"># project context — yours, or a host repo's</span>
├─ <span class="ft-dir">skills/</span>               <span class="ft-note"># reusable markdown expertise</span>
├─ <span class="ft-dir">tools/</span>                <span class="ft-note"># code tools · the filename is the name</span>
│   ├─ lookup-order.ts
│   └─ post-review.ts
├─ <span class="ft-dir ft-accent">channels/</span>             <span class="ft-note ft-accent"># a file IS a channel</span>
│   ├─ github.ts
│   └─ telegram.ts
├─ <span class="ft-dir">schedules/</span>            <span class="ft-note"># cron time triggers</span>
├─ reference.md          <span class="ft-note"># any markdown becomes context</span>
└─ fastagent.config.mjs  <span class="ft-note"># deployment choices</span></code></pre>

          <ul class="shape-notes">
            <li><strong>Bring your existing definition.</strong> An <code>AGENTS.md</code> plus <code>skills/</code> your coding agent already vibed is enough.</li>
            <li><strong>No registry, no boilerplate.</strong> A file in <code>channels/</code> is a channel. A file in <code>tools/</code> is a tool. Drop it in — it's live.</li>
            <li><strong>Typed tools.</strong> Zod validates every input before it runs — nothing hidden between the model and your code.</li>
            <li><strong>No build step.</strong> <code>fastagent dev</code> runs the directory. Ship the directory. That's the artifact.</li>
          </ul>
        </div>

        <p class="design-center"><span class="hash">#</span> every file is optional · point at a directory <span class="tp">→</span> get a live agent</p>
      </section>

      <!-- 04 ADD IT TO YOUR APP ──────────────────────────────────────────────────── -->
      <section class="section shell" aria-labelledby="embed-title">
        <header class="section-head">
          <span class="section-index"><span class="hash">#</span> 04 · add it to your app</span>
          <h2 id="embed-title">One import.<br /><em>An agent inside your app.</em></h2>
          <p class="section-lede">
            Call it like any function — from a request handler, a queue consumer,
            a background job — or mount it as a route in the app you already ship.
            FastAgent composes with your app, never owns it.
          </p>
        </header>

        <div class="tabs">
          {embedFrameworks.map((fw, i) => (
            <input type="radio" name="fw" id={`fw-${fw.id}`} checked={i === 0} class="tabs-radio" />
          ))}
          <div class="tabs-labels">
            {embedFrameworks.map((fw) => (
              <label for={`fw-${fw.id}`} class="tabs-label" data-tab={fw.id}>
                <BrandIcon name={fw.icon} size={13} />
                {fw.label}
              </label>
            ))}
          </div>
          {embedFrameworks.map((fw) => (
            <Code code={fw.code} lang="ts" theme={fastagentCode} class="tab-panel" data-panel={fw.id} />
          ))}
        </div>

        <ul class="keep-list" aria-label="What stays yours">
          <li>your auth</li>
          <li>your database</li>
          <li>your routes</li>
          <li>your sessions</li>
          <li>your infra</li>
        </ul>

        <p class="section-follow"><a class="text-link" href="/docs/embedding/">Embedding guide →</a></p>
      </section>

      <!-- 05 RUN IT AS A LIVE SERVICE ───────────────────────────────────────────────── -->
      <section class="section shell" aria-labelledby="channels-title">
        <header class="section-head">
          <span class="section-index"><span class="hash">#</span> 05 · run it as a live service</span>
