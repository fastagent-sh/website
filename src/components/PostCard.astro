---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, date, excerpt, tags, featured } = post.data;
const dateLabel = date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
const search = [title, excerpt, ...tags].join(" ").toLowerCase();
---

<article class="post-card" data-search={search}>
  <a href={`/blog/${post.id}/`}>
    <header class="post-meta">
      <time datetime={date.toISOString().slice(0, 10)}>{dateLabel}</time>
      {featured && <span class="post-featured">featured</span>}
    </header>
    <h2>{title}</h2>
    <p>{excerpt}</p>
    <footer class="post-tags" aria-label="Tags">
      {tags.map((t) => (
        <span class="post-tag"># {t}</span>
      ))}
    </footer>
  </a>
</article>
