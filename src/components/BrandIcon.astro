---
import { brandIcons } from "./brand-icons";

interface Props {
  name: string;
  size?: number;
  title?: string;
  color?: string;
}

const { name, size = 16, title, color } = Astro.props;
const icon = brandIcons[name];
if (!icon) throw new Error(`Unknown brand icon: ${name}`);
const body = typeof icon === "object" ? icon : undefined;
---

<svg
  width={size}
  height={size}
  viewBox={body ? body.viewBox : "0 0 24 24"}
  style={body && color ? `color:${color}` : undefined}
  aria-hidden={title ? undefined : "true"}
  role={title ? "img" : undefined}
>
  {title && <title>{title}</title>}
  {body ? <g set:html={body.body} /> : <path fill={color ?? "currentColor"} d={icon as string} />}
</svg>
