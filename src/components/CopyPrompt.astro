---
interface Props {
  compact?: boolean;
  text?: string;
  label?: string;
}

export const DEFAULT_PROMPT = "Read https://fastagent.sh/start.md and build an agent in this project.";

const { compact = false, text = DEFAULT_PROMPT, label = "Copy prompt" } = Astro.props;
---

<div class:list={["prompt", { compact }]}>
  <code>{text}</code>
  <div class="prompt-action">
    <button type="button" data-copy-prompt={text} data-track-method="agent-prompt" data-track-placement="cta">{label}</button>
    <span aria-live="polite" data-copy-status></span>
  </div>
</div>

<script>
  import "../scripts/copy";
</script>
