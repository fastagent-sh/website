{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fastagent-www",
  "compatibility_date": "2026-07-10",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./redirects/www",
    "not_found_handling": "none"
  },
  "routes": [
    {
      "pattern": "www.fastagent.sh",
      "custom_domain": true
    }
  ]
}
